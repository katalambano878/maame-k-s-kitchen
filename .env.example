# ============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local and fill in your own values.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://maamekskitchen.ca
NEXT_PUBLIC_SITE_NAME=maamekskitchen

# ----------------------------------------------------------------------------
# Store Contact
# ----------------------------------------------------------------------------
NEXT_PUBLIC_STORE_PHONE=5875822421
NEXT_PUBLIC_STORE_EMAIL=hello@maamekskitchen.ca
NEXT_PUBLIC_STORE_ADDRESS=Cornerstone, Calgary, AB
NEXT_PUBLIC_STORE_CITY=Calgary
NEXT_PUBLIC_STORE_REGION=Alberta
NEXT_PUBLIC_STORE_COUNTRY=Canada_CODE

# ----------------------------------------------------------------------------
# Supabase (https://supabase.com)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# ----------------------------------------------------------------------------
# Email (https://resend.com)
# ----------------------------------------------------------------------------
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@maamekskitchen.ca
ADMIN_EMAIL=hello@maamekskitchen.ca

# ----------------------------------------------------------------------------
# Payments - Stripe (https://stripe.com)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ----------------------------------------------------------------------------
# SMS (optional — separate from payment processing)
# ----------------------------------------------------------------------------
# MOOLRE_SMS_API_KEY=YOUR_MOOLRE_SMS_API_KEY
# SMS_SENDER_ID=MaameKitch

# ----------------------------------------------------------------------------
# Analytics & Verification (optional)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=YOUR_GA4_MEASUREMENT_ID
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=YOUR_GOOGLE_VERIFICATION_CODE

# ----------------------------------------------------------------------------
# Google reCAPTCHA v3 (optional)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
# RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY

# ----------------------------------------------------------------------------
# Admin user creation (used by `npm run create-admin` only)
# ----------------------------------------------------------------------------
CREATE_ADMIN_EMAIL=admin@maamekskitchen.ca
CREATE_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# ----------------------------------------------------------------------------
# Cron jobs (optional)
# ----------------------------------------------------------------------------
# CRON_SECRET=YOUR_CRON_SECRET